# ── Proveedor LLM ──────────────────────────────────────────────
# Opciones: groq | openai | anthropic
LLM_PROVIDER=openai

# API Key del proveedor seleccionado
LLM_API_KEY=

# Modelo a usar según el proveedor:
#   groq:      llama3-8b-8192 | mixtral-8x7b-32768 | llama3-70b-8192
#   openai:    gpt-4o-mini | gpt-4o
#   anthropic: claude-3-haiku-20240307 | claude-3-5-sonnet-20241022
LLM_MODEL=

# ── Plataformas externas por empresa ──────────────────────────
# Solo requerido si la empresa tiene plataforma externa real
# GASES_ORINOCO_API_KEY=your_key_here

# ── Servicios externos de prioridad ───────────────────────────
# Requerido SOLO si MENSAJERIA_DEL_VALLE tiene prioridad_externa.activa=true
# MENSAJERIA_VALLE_PRIORITY_URL=http://localhost:9000/prioridad

# ── Configuración del servidor ────────────────────────────────
APP_HOST=
APP_PORT=
APP_ENV=
